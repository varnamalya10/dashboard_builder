{
  "name": "custom-dashboard-builder",
  "version": "1.0.0",
  "description": "A full-stack dashboard builder application",
  "main": "index.js",
  "scripts": {
    "dev": "node scripts/dev-scripts.js dev",
    "build": "node scripts/dev-scripts.js build",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "sample-data": "node scripts/dev-scripts.js sample-data",
    "default-dashboard": "node scripts/dev-scripts.js default-dashboard",
    "clear-data": "node scripts/dev-scripts.js clear-data",
    "setup": "npm run install-all && npm run sample-data && npm run default-dashboard",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "start": "npm run dev"
  },
  "keywords": ["dashboard", "react", "node", "mysql", "express"],
  "author": "Dashboard Builder Team",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
